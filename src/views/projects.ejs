<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
        <h2>Upcoming Service Projects</h2>
        <ul>
            <% projects.forEach(project => { %>
            <li>
                <%= new Date(project.project_date).toLocaleDateString() %>:
                <%= project.title %>
                (<strong><%= project.organization_name %></strong>)
            </li>
            <% }) %>
        </ul>
</main>

<%- include('partials/footer') %>